{
  "name": "crusadernoremorsemapextractor",
  "version": "1.0.0",
  "description": "renders *crusader: no remorse* game data files into high resolution image files",
  "main": "dist/index.js",
  "bin": {
    "crusader-map-extractor": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist cache",
    "demo:overview": "node dist/index.js render-level --input-data-dir=\"gog/Crusader No Remorse\" --level=1 --scale 0.25 --output=demo_overview.png",
    "demo:zoomed": "node dist/index.js render-area --input-data-dir=\"gog/Crusader No Remorse\" --level=1 --x=13892 --y=13528 --width=4344 --height=2308 --output=demo_zoomed.png",
    "shapes": "node dist/index.js dump-shapes --input-data-dir=\"gog/Crusader No Remorse\" --output-dir=shapes",
    "shapes:1000": "node dist/index.js dump-shapes --input-data-dir=\"gog/Crusader No Remorse\" --output-dir=shapes --start=1000",
    "info": "node dist/index.js info --input-data-dir=\"gog/Crusader No Remorse\"",
    "stats": "node dist/index.js render-level --input-data-dir=\"gog/Crusader No Remorse\" --level=1 --stats --scale 0.25 --output=stats.png",
    "glob-test": "node dist/index.js render-glob --input-data-dir=\"gog/Crusader No Remorse\" --glob=0 --output=glob_test.png",
    "export-all": "node dist/index.js export-all --input-data-dir=\"gog/Crusader No Remorse\" --output-dir=exports --scale 0.25",
    "serve": "node dist/index.js serve --input-data-dir=\"gog/Crusader No Remorse\"",
    "dev": "tsc --watch"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.3.3",
    "@types/sharp": "^0.32.0",
    "commander": "^14.0.3",
    "express": "^5.2.1",
    "pngjs": "^7.0.0",
    "sharp": "^0.34.5",
    "typescript": "^5.9.3"
  }
}
